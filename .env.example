# Core runtime
MDM_INPUT_PATH=data/sample_records.csv
MDM_CANDIDATE_SIMILARITY=0.30
MDM_PROFILE_OUTPUT_PATH=docs/data_profile.md
MDM_ENABLE_LLM_TRANSLATION=false
MDM_ENABLE_LLM_ABBREVIATION_EXPANSION=false

# Groq selections for translation and reasoning
GROQ_API_KEY=
GROQ_TRANSLATION_MODEL=llama-3.3-70b-versatile
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_ABBREVIATION_MODEL=llama-3.3-70b-versatile

# Google Maps selections for address-aware matching
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_ADDRESS_VALIDATION_BASE_URL=https://addressvalidation.googleapis.com/v1:validateAddress
