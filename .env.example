# Core runtime
MDM_DATA_DIR=MDM- Match and Merge data
MDM_PROFILE_OUTPUT_PATH=docs/data_profile.md
MDM_GOLDEN_RECORD_OUTPUT_PATH=outputs/golden_records.csv
MDM_MATCH_OUTPUT_PATH=outputs/match_results.csv
MDM_VALIDATION_OUTPUT_PATH=docs/validation_results.md
MDM_CALIBRATION_OUTPUT_PATH=docs/calibration_report.md
MDM_ENABLE_LLM_TRANSLATION=false
MDM_ENABLE_LLM_ABBREVIATION_EXPANSION=false

# Groq selections for translation and reasoning
GROQ_API_KEY=
GROQ_TRANSLATION_MODEL=llama-3.3-70b-versatile
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_ABBREVIATION_MODEL=llama-3.3-70b-versatile

# Azure Maps selections for address-aware matching
AZURE_MAPS_API_KEY=
AZURE_MAPS_GEOCODING_BASE_URL=https://atlas.microsoft.com/geocode
AZURE_MAPS_API_VERSION=2025-01-01
